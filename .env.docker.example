# Copy this file to .env if you want Docker Compose to auto-load local values.
# Do not commit real secrets.

SECRET_KEY=change-me
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_CHAT_MODEL=gpt-4o-mini

FIREBASE_ADMIN_SDK_PATH=/app/secrets/firebase-admin-sdk.json
GOOGLE_CLOUD_PROJECT=
FIREBASE_PROJECT_ID=

RAG_FIRESTORE_COLLECTION=rag_embeddings
RAG_EMBEDDING_MODEL=text-embedding-3-large
RAG_EMBEDDING_DIMENSIONS=2048

# Use the default PyPI index first. If Docker receives 403/SSL errors from
# files.pythonhosted.org on your network, you can temporarily switch to a mirror.
PIP_INDEX_URL=https://pypi.org/simple
PIP_TRUSTED_HOSTS=pypi.org files.pythonhosted.org

NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
