# Copy to `.env.docker` or export these variables in your shell before running
# `docker compose up --build`. Do not commit real secrets.

POSTGRES_DB=intelliflow
POSTGRES_USER=intelliflow
POSTGRES_PASSWORD=intelliflow
POSTGRES_PORT=5432

BACKEND_PORT=8000
FRONTEND_PORT=3000

APP_ENV=development
APP_NAME=IntelliFlow
APP_VERSION=1.0.0
AUTH_MODE=hybrid
DOCKER_DATABASE_URL=postgresql+psycopg://intelliflow:intelliflow@postgres:5432/intelliflow
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8081,http://127.0.0.1:8081,exp://localhost:8081
SUPPORT_EMAIL=support@intelliflow.local

DEMO_MODE_ENABLED=true
DEMO_ORG_ID=demo-org
DEMO_USER_ID=demo-user
DEMO_USER_PLAN=BOOST
TEST_PLAN_OVERRIDE=BOOST
ENABLE_MCP_DEV_ENDPOINTS=true
AI_PROVIDER=template

FIREBASE_ADMIN_SDK_PATH=/app/secrets/firebase-admin-sdk.json
GOOGLE_CLOUD_PROJECT=
FIREBASE_PROJECT_ID=
OPENAI_API_KEY=

FREE_API_CACHE_TTL_SECONDS=900
DATA_GOV_MY_ENABLED=true
BNM_OPENAPI_ENABLED=true
OSM_NOMINATIM_ENABLED=true
OSM_OVERPASS_ENABLED=true
OPEN_METEO_ENABLED=true
OPEN_METEO_MARINE_ENABLED=true
GOOGLE_TRENDS_ALPHA_ENABLED=false
GOOGLE_TRENDS_API_KEY=

SHOPEE_OPEN_PLATFORM_ENABLED=false
SHOPEE_APP_ID=
SHOPEE_APP_SECRET=
LAZADA_OPEN_PLATFORM_ENABLED=false
LAZADA_APP_KEY=
LAZADA_APP_SECRET=
TIKTOK_SHOP_ENABLED=false
TIKTOK_APP_KEY=
TIKTOK_APP_SECRET=

PAID_MARKET_INTELLIGENCE_ENABLED=false
PAID_LOGISTICS_PROVIDER_ENABLED=false
PAID_WAREHOUSE_PROVIDER_ENABLED=false

NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
