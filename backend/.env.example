APP_ENV=development

# Database
DATABASE_URL=postgresql+psycopg://intelliflow:intelliflow@localhost:5432/intelliflow

# Security
SECRET_KEY=replace-with-a-long-random-secret

# AI provider
AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_CHAT_MODEL=gpt-5.4-mini
AI_DEFAULT_MODEL=gpt-5.4-mini
AI_STRONG_MODEL=gpt-5.4
AI_USE_STRONG_MODEL=false
AI_MONTHLY_BUDGET_USD=5

# Firebase Admin SDK
FIREBASE_ADMIN_SDK_PATH=backend/secrets/firebase-admin-sdk.json

# Optional runtime controls
DEMO_MODE_ENABLED=false
ENABLE_MCP_DEV_ENDPOINTS=false
TEST_PLAN_OVERRIDE=
