{
  "expo": {
    "name": "IntelliFlow Mobile",
    "slug": "intelliflow-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/logo/intelliflow-logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#140f0c"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#140f0c"
      },
      "edgeToEdgeEnabled": true
    },
    "extra": {
      "apiUrl": "https://YOUR_HOSTED_DEMO_BACKEND_URL"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    }
  }
}
